FROM golang:1.22-alpine AS build

WORKDIR /src
COPY BackendGo/go.mod BackendGo/go.sum ./
RUN go mod download
COPY BackendGo/ ./
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/backend-go ./cmd/backend

FROM alpine:3.20

RUN apk add --no-cache ffmpeg ca-certificates
RUN adduser -D -H app
WORKDIR /app
COPY --from=build /out/backend-go /app/backend-go
USER app
EXPOSE 18081
ENTRYPOINT ["/app/backend-go"]
