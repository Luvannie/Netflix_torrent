# Netflix Torrent local/desktop configuration.
#
# Copy to `.env` when using docker-compose.local.yml. The desktop launcher will
# generate its own runtime config under the user's app data directory.

SPRING_PROFILES_ACTIVE=worker,desktop

# PostgreSQL sidecar
POSTGRES_DB=netflixtorrent
POSTGRES_USER=netflixtorrent
POSTGRES_PASSWORD=local_postgres_password

# TMDB
TMDB_API_KEY=YOUR_TMDB_API_KEY_HERE
TMDB_READ_ACCESS_TOKEN=

# Torrent source search: jackett, prowlarr, or both
TORRENT_SEARCH_PROVIDER=prowlarr
TORRENT_SEARCH_MAX_RESULTS=50

# Local Docker sidecar URLs used from inside the backend container.
# For host/launcher runs, application-desktop.yml defaults to 127.0.0.1 ports.
JACKETT_URL=http://jackett:9117
JACKETT_API_KEY=YOUR_JACKETT_API_KEY_HERE
JACKETT_INDEXERS=all

PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=YOUR_PROWLARR_API_KEY_HERE

# qBittorrent Web UI credentials.
QBITTORRENT_URL=http://qbittorrent:8082
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=YOUR_QBITTORRENT_PASSWORD_HERE

# Docker local E2E path. Launcher runs should use a Windows absolute path
# selected by the user and pass the same path to qBittorrent and backend.
DOWNLOAD_DEFAULT_SAVE_PATH=/data/media

# Desktop local-token. The real launcher should generate this per install/run.
APP_LOCAL_TOKEN_ENABLED=true
APP_LOCAL_TOKEN=replace-with-random-local-token

# ffprobe is bundled in the local backend image and should be bundled beside the launcher.
FFPROBE_PATH=ffprobe
FFPROBE_TIMEOUT_SECONDS=30

# LinuxServer sidecars
PUID=1000
PGID=1000
TZ=Asia/Ho_Chi_Minh
