{
  "requests": [
    {
      "name": "health",
      "method": "GET",
      "path": "/api/v1/health",
      "headers": {
        "X-Request-Id": "parity-health"
      }
    },
    {
      "name": "system_status",
      "method": "GET",
      "path": "/api/v1/system/status",
      "headers": {
        "X-Request-Id": "parity-status"
      }
    },
    {
      "name": "storage_profiles_list",
      "method": "GET",
      "path": "/api/v1/settings/storage-profiles",
      "headers": {
        "X-Request-Id": "parity-profiles"
      }
    },
    {
      "name": "catalog_list",
      "method": "GET",
      "path": "/api/v1/catalog",
      "headers": {
        "X-Request-Id": "parity-catalog"
      }
    },
    {
      "name": "catalog_search",
      "method": "GET",
      "path": "/api/v1/catalog/search?query=matrix",
      "headers": {
        "X-Request-Id": "parity-search"
      }
    },
    {
      "name": "catalog_genres",
      "method": "GET",
      "path": "/api/v1/catalog/genres",
      "headers": {
        "X-Request-Id": "parity-genres"
      }
    },
    {
      "name": "search_jobs_list",
      "method": "GET",
      "path": "/api/v1/search/jobs",
      "headers": {
        "X-Request-Id": "parity-jobs"
      }
    },
    {
      "name": "downloads_list",
      "method": "GET",
      "path": "/api/v1/downloads",
      "headers": {
        "X-Request-Id": "parity-downloads"
      }
    },
    {
      "name": "library_list",
      "method": "GET",
      "path": "/api/v1/library",
      "headers": {
        "X-Request-Id": "parity-library"
      }
    }
  ],
  "write_requests": [
    {
      "name": "create_storage_profile",
      "method": "POST",
      "path": "/api/v1/settings/storage-profiles",
      "headers": {
        "X-Request-Id": "parity-create-profile",
        "X-App-Local-Token": "token",
        "Content-Type": "application/json"
      },
      "body": {
        "name": "Test Profile",
        "basePath": "/tmp/test",
        "priority": 1,
        "active": false
      }
    },
    {
      "name": "create_search_job",
      "method": "POST",
      "path": "/api/v1/search/jobs",
      "headers": {
        "X-Request-Id": "parity-create-job",
        "X-App-Local-Token": "token",
        "Content-Type": "application/json"
      },
      "body": {
        "query": "test movie"
      }
    },
    {
      "name": "create_download_task",
      "method": "POST",
      "path": "/api/v1/downloads",
      "headers": {
        "X-Request-Id": "parity-create-download",
        "X-App-Local-Token": "token",
        "Content-Type": "application/json"
      },
      "body": {
        "searchResultId": 1,
        "filePath": "/tmp/test.mkv"
      }
    }
  ]
}
